# ==============================
# Dependencies
# ==============================
# Node modules (never push - huge size)
node_modules/
backend/node_modules/
frontend/node_modules/

# ==============================
# Environment Files (Secrets)
# ==============================
# Sensitive credentials (DB, JWT, Email, API keys)
.env
.env.*
backend/.env
backend/.env.*
frontend/.env.production
frontend/.env.*

# ==============================
# Build / Production Files
# ==============================
# Auto-generated build folders
frontend/build/
frontend/dist/
backend/build/
backend/dist/

# ==============================
# Logs & Debug Files
# ==============================
# Debug logs (not useful in repo)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================
# OS Generated Files
# ==============================
# System files (Windows / Mac)
.DS_Store
Thumbs.db

# ==============================
# IDE / Editor Files
# ==============================
# VS Code & editor settings
.vscode/
.idea/

# ==============================
# Testing & Coverage
# ==============================
# Test coverage reports
coverage/

# ==============================
# Optional (if used later)
# ==============================
# Cache & temp files
.cache/
.tmp/